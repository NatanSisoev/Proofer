{
  "name": "proofer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "import": "node --experimental-sqlite scripts/import-vault.mjs",
    "embed": "node --experimental-sqlite --env-file-if-exists=.env.local scripts/embed.mjs",
    "dev": "cross-env NODE_OPTIONS=--experimental-sqlite next dev --turbo",
    "build": "cross-env NODE_OPTIONS=--experimental-sqlite next build",
    "start": "cross-env NODE_OPTIONS=--experimental-sqlite next start",
    "check-db": "cross-env NODE_OPTIONS=--experimental-sqlite node scripts/check-db.mjs",
    "test": "cross-env NODE_OPTIONS=\"--experimental-sqlite --import tsx\" node --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "cytoscape": "^3.30.2",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.11",
    "lucide-react": "^1.21.0",
    "next": "^15.1.6",
    "node-tikzjax": "^1.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.22.5",
    "typescript": "^5.7.3"
  }
}
